# Copy to .env - or run: make setup-env (pulls region + buckets from Terraform)

# Must match the region you deployed with (terraform apply -var="aws_region=...")
AWS_REGION=us-east-1

# Athena (dashboard - default)
GLUE_DATABASE=data_pipeline_demo_catalog
ATHENA_WORKGROUP=data-pipeline-demo
ATHENA_RESULTS_BUCKET=data-pipeline-demo-athena-ACCOUNT_ID
GLUE_TABLE=processed

# Redshift (optional - for full evaluation criteria)
USE_REDSHIFT=false
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=sales
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=
S3_BUCKET=
REDSHIFT_IAM_ROLE_ARN=
